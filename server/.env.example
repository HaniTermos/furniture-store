# ═══════════════════════════════════════════════════════════════
#  .env.example — HTW Furniture Store Server
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ─── Server ─────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── JWT ────────────────────────────────────────────────────
# Must be at least 32 characters in production
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# ─── Session ────────────────────────────────────────────────
# Must be at least 32 characters in production
SESSION_SECRET=change-me-to-a-long-random-session-secret

# ─── Database (PostgreSQL) ───────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_NAME=furniture_store
DB_USER=postgres
DB_PASSWORD=your-db-password

# ─── Client URL (CORS + Email Links) ────────────────────────
CLIENT_URL=http://localhost:3000

# ─── Google OAuth (optional) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─── SMTP Email (optional) ──────────────────────────────────
# Falls back to console logging if not configured
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_NAME=HTW Furniture
FROM_EMAIL=noreply@htwfurniture.com

# ─── Cloudinary (optional — for cloud image storage) ────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Stripe (optional — for payment processing) ─────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

